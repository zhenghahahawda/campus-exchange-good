<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.exchange.mapper.UserMapper">

    <!-- 调用存储过程生成用户ID -->
    <select id="generateUserId" statementType="CALLABLE" resultType="java.lang.Integer">
        {CALL generate_user_id(#{userId, mode=OUT, jdbcType=INTEGER})}
    </select>

    <update id="updateThemePreferenceByOldPreference">
        UPDATE users
        SET theme_preference = #{newPreference},
            updated_at = NOW()
        WHERE theme_preference = #{oldPreference}
          AND deleted_at IS NULL
    </update>

</mapper>
