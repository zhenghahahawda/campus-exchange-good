# 环境变量配置示例
# 复制此文件为 .env 并填入实际的密钥

# ============================================
# 人机验证配置
# ============================================

# Google reCAPTCHA v3（无感验证）
# 申请地址: https://www.google.com/recaptcha/admin
RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET_KEY=

# Google reCAPTCHA v2（复选框验证）
# 申请地址: https://www.google.com/recaptcha/admin
RECAPTCHA_V2_SITE_KEY=
RECAPTCHA_V2_SECRET_KEY=

# hCaptcha（隐私友好的替代方案）
# 申请地址: https://www.hcaptcha.com/
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# 腾讯云验证码（国内推荐）
# 申请地址: https://cloud.tencent.com/product/captcha
TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET=

# 阿里云验证码（国内推荐）
# 申请地址: https://www.aliyun.com/product/captcha
ALIYUN_CAPTCHA_APP_KEY=
ALIYUN_CAPTCHA_ACCESS_KEY_ID=
ALIYUN_CAPTCHA_ACCESS_KEY_SECRET=

# ============================================
# 数据库配置
# ============================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=exchange_system

# ============================================
# JWT 配置
# ============================================

JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 服务器配置
# ============================================

PORT=10010
HOST=0.0.0.0
NODE_ENV=development
API_URL=http://localhost:10010/

# ============================================
# Redis 配置（可选）
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
